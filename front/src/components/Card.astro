---
import "../styles/global.css";

interface Props {
  text: string;
  image: string;
}

---

<div class="card">
  <img src={Astro.props.image} class="card-image" />
  <div class="card-content">
    <h3 class="card-text">{Astro.props.text}</h3>
    </div>
</div>

<style>
  .card {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    width: 300px;
    height: 500px;
    margin: 1rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease-in-out;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .card-image {
    width: 100%;
    height: 170px;
    display: block;
    object-fit: cover;
  }

  .card-content {
    padding: 1rem;
  }

  .card-text {
    color: #fff;
    font-size: 1.2rem;
    font-weight: 400;
    margin: 0;
    text-align: justify;
  }

  @media (max-width: 960px) {
    .card {
      margin: 0rem;
    }
  }
</style>